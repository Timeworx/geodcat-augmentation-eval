      "dct:title": {
        "@language": "en",
        "@value": "Fisheries Protection Zone around Svalbard"
      },
      "dct:description": {
        "@language": "en",
        "@value": "An adjacent belt at sea, the breadth of which is measured from the outer limit of territorial waters, calculated 12 Nautical Miles from the baselines of Svalbard, to the outer limit calculated 200 Nautical Miles from the same baseline, and which is bounded by the Economic Zone for Norway and the agreed delimitation lines where there are less than 400 nm to another state baseline"
      },
